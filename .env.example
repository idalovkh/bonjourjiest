# Telegram — обязательно для /api/lead/* на проде
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_CHAT_ID=-1001234567890

# Прокси для запросов в Telegram API (если api.telegram.org недоступен напрямую)
# TELEGRAM_PROXY_URL=http://user:pass@host:port
# TELEGRAM_PROXY_URL=socks5://user:pass@host:port
# TELEGRAM_PROXY_URL=host:port:user:pass   # короткий формат провайдера

# Локальная разработка (опционально)
# API_PORT=3002
# VITE_API_ORIGIN=http://localhost:3002   # для npm run dev:full
# VITE_API_ORIGIN=https://bonjourjiest.com   # для npm run dev (прокси на прод API)

# Подробные логи API + detail в JSON-ответе (для отладки)
# DEBUG_LEAD=1
