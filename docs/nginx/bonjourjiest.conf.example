# /etc/nginx/sites-available/bonjourjiest.com
# ln -s .../bonjourjiest.com /etc/nginx/sites-enabled/

server {
    listen 80;
    listen [::]:80;
    server_name bonjourjiest.com www.bonjourjiest.com;
    return 301 https://bonjourjiest.com$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name www.bonjourjiest.com;

    # ssl_certificate ...
    # ssl_certificate_key ...

    return 301 https://bonjourjiest.com$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name bonjourjiest.com;

    root /var/www/bonjourjiest;
    index index.html;

    # ssl_certificate ...
    # ssl_certificate_key ...

    location /api/ {
        proxy_pass http://127.0.0.1:3002;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location / {
        try_files $uri $uri/ /index.html;
    }
}
